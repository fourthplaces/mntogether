# Development Dockerfile for Next.js with hot-reload
FROM node:22-alpine

WORKDIR /app

# Install dependencies globally for faster startup
RUN corepack enable && corepack prepare yarn@4.12.0 --activate

# Copy workspace root files
COPY package.json yarn.lock .yarnrc.yml ./

# Copy shared package
COPY packages/shared ./packages/shared

# Copy app package
COPY packages/admin-app/package.json ./packages/admin-app/

# Install dependencies (baked into image for fast first start)
RUN yarn install

# Copy entrypoint script that auto-updates deps when yarn.lock changes
COPY scripts/docker-entrypoint-nextjs.sh /usr/local/bin/docker-entrypoint-nextjs.sh
RUN chmod +x /usr/local/bin/docker-entrypoint-nextjs.sh

# Expose Next.js dev server port
EXPOSE 3000

# Set environment
ENV NODE_ENV=development
ENV NEXT_TELEMETRY_DISABLED=1
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

WORKDIR /app/packages/admin-app

# Entrypoint checks for stale node_modules, then runs CMD
ENTRYPOINT ["docker-entrypoint-nextjs.sh"]
CMD ["yarn", "dev"]
